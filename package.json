{
  "name": "gemini-web-utility",
  "version": "0.9.10",
  "description": "Quality-of-life utilities for the Gemini web app as a Manifest V3 extension.",
  "keywords": [
    "gemini",
    "chrome-extension",
    "manifest-v3",
    "productivity",
    "playwright"
  ],
  "homepage": "https://github.com/Setmaster/gemini-web-utility",
  "bugs": {
    "url": "https://github.com/Setmaster/gemini-web-utility/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Setmaster/gemini-web-utility.git"
  },
  "files": [
    "README.md",
    "content_script.js",
    "icons",
    "manifest.json",
    "service_worker.js"
  ],
  "scripts": {
    "build:zip": "bash scripts/build-webstore-zip.sh",
    "test:unit": "node --test tests/core.test.js tests/metadata.test.js",
    "test:mv3": "playwright test tests/mv3-extension.spec.js --config=tests/playwright.mv3.config.js",
    "test:live": "playwright test tests/live-gemini.spec.js --config=tests/playwright.live.config.js",
    "test": "npm run test:unit && npm run test:mv3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1"
  }
}
