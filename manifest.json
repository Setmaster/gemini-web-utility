{
  "manifest_version": 3,
  "name": "Gemini Web Utility",
  "version": "0.9.0",
  "description": "Utilities for the Gemini web app.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://*.googleusercontent.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "gemini-web-utility.user.js"
      ],
      "run_at": "document_start"
    }
  ]
}
