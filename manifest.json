{
  "manifest_version": 3,
  "name": "Gemini Web Utility",
  "version": "0.9.10",
  "description": "Quality-of-life utilities for the Gemini web app.",
  "action": {
    "default_title": "Gemini Web Utility"
  },
  "icons": {
    "16": "icons/gwu-16.png",
    "32": "icons/gwu-32.png",
    "48": "icons/gwu-48.png",
    "128": "icons/gwu-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://lh3.google.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_start"
    }
  ]
}
